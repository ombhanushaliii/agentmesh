# Copy this file to .env.local and fill in the values.
# Next.js reads .env.local — NOT the root .env — so this file is required.

# Wallet private key for the planner agent (fund on 0G Galileo testnet: https://faucet.0g.ai)
PLANNER_PRIVATE_KEY=

# Gemini API key for agent inference
GEMINI_API_KEY=

# Gensyn AXL bridge URL (run ./node -config node-config.json first)
AXL_BRIDGE_URL=http://127.0.0.1:9102

# 0G Chain RPC
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
KV_RPC_URL=https://storagerpc-testnet.0g.ai
FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
