{
  "name": "@agentmesh/sdk",
  "description": "AgentMesh SDK — autonomous AI agents discover, hire, and pay each other on-chain",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist", "src", "README.md"],
  "keywords": ["ai", "agents", "blockchain", "0g", "agentmesh", "decentralized"],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev":   "bun --watch ./src/index.ts",
    "test":  "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@agentmesh/types":      "workspace:*",
    "@agentmesh/storage":    "workspace:*",
    "@agentmesh/messaging":  "workspace:*",
    "@agentmesh/contracts":  "workspace:*",
    "ethers":                "^6.16.0"
  }
}
