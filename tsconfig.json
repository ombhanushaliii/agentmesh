{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@agentmesh/types":     ["./shared/types/index.ts"],
      "@agentmesh/storage":   ["./packages/storage/src/index.ts"],
      "@agentmesh/contracts": ["./packages/contracts/src/index.ts"],
      "@agentmesh/messaging": ["./packages/messaging/src/index.ts"],
      "@agentmesh/sdk":       ["./packages/sdk/src/index.ts"],
      "@agentmesh/agents":    ["./packages/agents/src/index.ts"],
      "@agentmesh/settlement":["./packages/settlement/src/index.ts"]
    }
  }
}
